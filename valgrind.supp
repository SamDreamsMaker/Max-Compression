# MaxCompression Valgrind Suppressions
# Suppress known false positives from system libraries

# OpenMP runtime
{
   omp_runtime_leak
   Memcheck:Leak
   ...
   obj:*/libomp*.so*
}
{
   omp_runtime_leak2
   Memcheck:Leak
   ...
   obj:*/libgomp*.so*
}

# dlopen/dlclose
{
   dlopen_leak
   Memcheck:Leak
   ...
   fun:dlopen*
}
